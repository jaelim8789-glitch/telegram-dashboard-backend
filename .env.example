# === Database ===
# Host-run dev (uvicorn via venv) connects to the docker-compose port mapping on
# localhost. Inside docker-compose itself, the backend service overrides this to use the
# `db` hostname instead — see docker-compose.yml. On Render, set this to the Postgres
# instance's own connection string (with +asyncpg added — Render's default string uses
# the sync `postgresql://` scheme).
DATABASE_URL=postgresql+asyncpg://telegram_dashboard:telegram_dashboard@localhost:5432/telegram_dashboard

# === Telegram API ===
# Register an application at https://my.telegram.org -> API Development Tools.
# One app registration is reused to log in to every personal account managed here —
# Telegram accounts don't each need their own API ID/Hash.
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# === Auto-reply bot (optional) ===
# Only needed if you want the /autoreply remote-control bot (inline on/off buttons).
# The dashboard's own "자동 응답" tab toggles the same setting without this — leave blank
# to skip it entirely. Get a token from @BotFather on Telegram (/newbot).
# Note: the auto-reply listener itself needs a continuously-connected Telethon session
# (see README "배포 방법" — this feature is local/VM-only, it will not work reliably on
# a free host that sleeps on idle, such as Render's free tier).
TELEGRAM_BOT_TOKEN=

# === Official channel verification (free trial gate) ===
# Required for the "join our channel to start your free trial" signup flow
# (app/api/telegram_verify.py). Reuses TELEGRAM_BOT_TOKEN above — the same bot must be
# an admin of the official channel so getChatMember works for every member, not just
# ones who've messaged the bot before.
# Public @username of the bot (no leading @) — used only to build the
# t.me/<username>?start=<token> link shown to users, never a secret.
TELEGRAM_BOT_USERNAME=
# The official TeleMon channel: either "@channelusername" or a numeric chat id
# (e.g. -1001234567890 — get this by forwarding a channel message to @userinfobot,
# or via getChat once the bot is an admin).
TELEGRAM_OFFICIAL_CHANNEL_ID=

# === Guide Hub buttons ===
# JSON object mapping guide-hub button keys to their URLs. Only keys present in
# GUIDE_HUB_BUTTONS (app/services/guide_hub_service.py) are rendered; a key missing
# from this map simply omits that button. Example:
# TELEGRAM_GUIDE_HUB_LINKS_JSON={"homepage":"https://telemon.online","official_channel":"https://t.me/TeleMon_2","free_trial":"https://t.me/TeleMon_2/2"}
TELEGRAM_GUIDE_HUB_LINKS_JSON={}

# === Encryption ===
# Fernet key used to encrypt Telegram session strings before they're stored in Postgres.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Treat this like a credential — do not commit it, do not share it, back it up somewhere
# safe (losing it means every already-authenticated account has to re-verify).
ENCRYPTION_KEY=your_fernet_key

# === CORS ===
# Comma-separated origins allowed to call the API directly from a browser.
# With nginx same-origin proxy (/api/ → backend), CORS is not needed for
# browser requests — they're same-origin. Set this for external API clients.
# - Local host-run dev: http://localhost:3000
# - docker-compose (nginx-fronted): not needed, leave empty
# - Production with external clients: https://app.telemon.online,https://telemon.online
CORS_ORIGINS=http://localhost:3000,http://localhost

# === Environment ===
ENVIRONMENT=development
# Also controls whether /docs, /redoc, /openapi.json are exposed (see app/main.py) — set
# to false for anything resembling a real deployment.
DEBUG=true

# === Admin auth ===
# Fixed single-admin login for /admin/login (issues a JWT used both for /admin/* and as
# an alternative to X-API-Key on /api/*). Change ADMIN_PASSWORD and ADMIN_JWT_SECRET
# before deploying anywhere reachable outside localhost.
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_JWT_SECRET=your_jwt_signing_secret
ADMIN_JWT_EXPIRE_MINUTES=1440

# === 일반 사용자 로그인 (전화번호 인증, Sprint 6) ===
# "console" just logs the code (see `docker compose logs -f backend` / the terminal)
# instead of sending a real SMS — free, for local dev only. Switch to "twilio" or
# "coolsms" and fill in the matching credentials below before deploying for real use,
# since real SMS costs money per message.
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
COOLSMS_API_KEY=
COOLSMS_API_SECRET=
COOLSMS_PHONE_NUMBER=

# === Billing / 결제 (USDT + Telegram Stars) ===
# USDT를 받을 내 지갑 주소 (TRC20 권장)
USDT_WALLET_ADDRESS=0x0000000000000000000000000000000000000000
USDT_NETWORK=TRC20

# Frontend URL (for cross-domain redirects and payment success links)
# - Local dev: http://localhost:3000
# - Production (self-hosted via nginx): https://app.telemon.online
#   (or https://telemon.online if the public site handles payment flows)
FRONTEND_URL=http://localhost:3000
# Authenticated application dashboard domain (used for cross-domain links in
# signup/payment completion pages). Same as FRONTEND_URL in single-domain setups.
# In multi-domain production: https://app.telemon.online
# APP_URL=http://localhost:3000

# === Broadcast execution timeout (seconds, default 300) ===
# Must be >= 1.  Set higher for slow networks / large recipient lists.
# BROADCAST_TIMEOUT_SECONDS=300

# === Broadcast max retries (default 3) ===
# Number of times a failed broadcast can be manually retried.  Set to 0
# to disable retries entirely.
# BROADCAST_MAX_RETRIES=3
