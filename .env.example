# === Database ===
# Host-run dev (uvicorn via venv) connects to the docker-compose port mapping on
# localhost. Inside docker-compose itself, the backend service overrides this to use the
# `db` hostname instead — see docker-compose.yml. On Render, set this to the Postgres
# instance's own connection string (with +asyncpg added — Render's default string uses
# the sync `postgresql://` scheme).
DATABASE_URL=postgresql+asyncpg://telegram_dashboard:telegram_dashboard@localhost:5432/telegram_dashboard

# === Telegram API ===
# Register an application at https://my.telegram.org -> API Development Tools.
# One app registration is reused to log in to every personal account managed here —
# Telegram accounts don't each need their own API ID/Hash.
TELEGRAM_API_ID=your_api_id
TELEGRAM_API_HASH=your_api_hash

# === Auto-reply bot (optional) ===
# Only needed if you want the /autoreply remote-control bot (inline on/off buttons).
# The dashboard's own "자동 응답" tab toggles the same setting without this — leave blank
# to skip it entirely. Get a token from @BotFather on Telegram (/newbot).
# Note: the auto-reply listener itself needs a continuously-connected Telethon session
# (see README "배포 방법" — this feature is local/VM-only, it will not work reliably on
# a free host that sleeps on idle, such as Render's free tier).
TELEGRAM_BOT_TOKEN=

# === Encryption ===
# Fernet key used to encrypt Telegram session strings before they're stored in Postgres.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Treat this like a credential — do not commit it, do not share it, back it up somewhere
# safe (losing it means every already-authenticated account has to re-verify).
ENCRYPTION_KEY=your_fernet_key

# === CORS ===
# Comma-separated origins allowed to call the API directly from a browser.
# - Local host-run dev: http://localhost:3000 (or whatever port `next dev` picks)
# - docker-compose (nginx-fronted): not needed, frontend/backend share one origin
# - Vercel + Render split deployment: REQUIRED — set to your Vercel URL, e.g.
#   https://your-app.vercel.app (frontend and backend are on different origins there)
CORS_ORIGINS=http://localhost:3000,http://localhost

# === Environment ===
ENVIRONMENT=development
# Also controls whether /docs, /redoc, /openapi.json are exposed (see app/main.py) — set
# to false for anything resembling a real deployment.
DEBUG=true

# === Admin auth ===
# Fixed single-admin login for /admin/login (issues a JWT used both for /admin/* and as
# an alternative to X-API-Key on /api/*). Change ADMIN_PASSWORD and ADMIN_JWT_SECRET
# before deploying anywhere reachable outside localhost.
ADMIN_USERNAME=your_admin_username
ADMIN_PASSWORD=your_admin_password
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
ADMIN_JWT_SECRET=your_jwt_signing_secret
ADMIN_JWT_EXPIRE_MINUTES=1440
